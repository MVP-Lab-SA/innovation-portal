# ============================================================
# Innovation Center — Environment Variables
# ============================================================

# ---- 🗄️ Vercel Postgres (Neon) - auto-injected ----
POSTGRES_PRISMA_URL="postgres://..."
POSTGRES_URL_NON_POOLING="postgres://..."
POSTGRES_URL="postgres://..."
POSTGRES_USER="..."
POSTGRES_HOST="..."
POSTGRES_PASSWORD="..."
POSTGRES_DATABASE="..."

# ---- 📦 Vercel Blob - auto-injected ----
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ---- 📧 Resend (Email Magic Links) - optional ----
RESEND_API_KEY="re_..."
EMAIL_FROM="onboarding@resend.dev"

# ---- 🔐 Neon Auth - REQUIRED ----
# NEON_AUTH_BASE_URL is auto-injected when you enable Neon Auth in the Neon console.
NEON_AUTH_BASE_URL="https://...neon.tech/auth"
# Cookie signing secret — MUST be set in production (>=32 random chars).
# Generate with: openssl rand -base64 48
NEON_AUTH_COOKIE_SECRET="generate with: openssl rand -base64 48"

# ---- 🛡️ Authorization ----
# Bootstrap admin email — auto-promoted to ADMIN on first OTP sign-in.
ADMIN_EMAIL="admin@momah.gov.sa"
ALLOWED_DOMAINS="momah.gov.sa,gov.sa"
ALLOWED_EMAILS=""

# ---- 📝 Sanity CMS (Editorial content) ----
NEXT_PUBLIC_SANITY_PROJECT_ID="vhq6bivv"
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_PROJECT_ID="vhq6bivv"
SANITY_DATASET="production"
SANITY_API_READ_TOKEN=""    # Server-side only - keep secret
SANITY_API_WRITE_TOKEN=""   # Server-side only - keep secret
