# ============================================================
# Innovation Center — Vercel Environment Variables
# ============================================================
# Most of these are AUTO-INJECTED when you add integrations in Vercel:
#   - "Vercel Postgres" (Neon) → adds DB variables
#   - "Vercel Blob" → adds BLOB_READ_WRITE_TOKEN
#   - "Resend" → adds RESEND_API_KEY
# 
# You only need to manually add the AUTH ones at the bottom.
# ============================================================

# ---- AUTO-INJECTED by Vercel Postgres (Neon) integration ----
POSTGRES_PRISMA_URL="postgres://..."        # Pooled - used by Prisma client
POSTGRES_URL_NON_POOLING="postgres://..."   # Direct - used by Prisma migrations
POSTGRES_URL="postgres://..."
POSTGRES_USER="..."
POSTGRES_HOST="..."
POSTGRES_PASSWORD="..."
POSTGRES_DATABASE="..."

# ---- AUTO-INJECTED by Vercel Blob integration ----
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ---- AUTO-INJECTED by Resend integration (or add manually) ----
RESEND_API_KEY="re_..."
EMAIL_FROM="onboarding@resend.dev"  # Use your own domain after verifying

# ---- REQUIRED: NextAuth ----
NEXTAUTH_URL="https://your-project.vercel.app"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ---- OPTIONAL: Google OAuth (only if you want this as a sign-in option) ----
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ---- REQUIRED: Authorization ----
ADMIN_EMAIL="aj.alqahtani@momah.gov.sa"
ALLOWED_DOMAINS="momah.gov.sa,gov.sa"
ALLOWED_EMAILS=""  # Optional: comma-separated list of extra emails to allow
