{
  "name": "innovation-center",
  "version": "2.0.0",
  "private": true,
  "description": "مركز الابتكار - Vercel + Neon Postgres + Neon Auth + Blob + Sanity",
  "engines": {
    "node": ">=20 <24"
  },
  "scripts": {
    "dev": "next dev -p 3002",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 3002",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "check:env": "node scripts/verify-env.mjs",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "import:business-challenges": "node scripts/import-business-challenges.mjs",
    "import:sandbox-applications": "node scripts/import-sandbox-applications.mjs",
    "import:experts": "node scripts/import-experts.mjs",
    "import:initiatives": "node scripts/import-initiatives.mjs",
    "import:tasks": "node scripts/import-tasks.mjs",
    "relink:tasks": "node scripts/relink-tasks.mjs",
    "normalize:business-challenges": "node scripts/normalize-business-challenges.mjs",
    "cleanup:sample-data": "node scripts/cleanup-sample-data.mjs",
    "create:campaigns": "node scripts/create-campaigns.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@neondatabase/serverless": "^0.9.4",
    "@prisma/adapter-neon": "^5.18.0",
    "@neondatabase/auth": "^0.4.1-beta",
    "@neondatabase/auth-ui": "^0.2.0-beta",
    "@vercel/blob": "^0.23.4",
    "@sanity/client": "^7.4.0",
    "@sanity/image-url": "^1.1.0",
    "next-sanity": "^9.8.31",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "recharts": "^2.12.7",
    "lucide-react": "^0.428.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.2",
    "date-fns": "^3.6.0",
    "xlsx": "^0.18.5",
    "sonner": "^1.5.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "prisma": "^5.18.0",
    "tsx": "^4.16.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5"
  }
}
